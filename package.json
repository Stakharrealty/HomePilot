{
  "name": "homepilot",
  "private": true,
  "description": "Test tooling for HomePilot (Ontario homebuyer affordability tool). See README.md and tests/ for details.",
  "scripts": {
    "test": "node tests/regression_suite.js index.html",
    "test:browser-load": "node tests/browser_load_verification.js",
    "test:smoke": "node tests/smoke_test.js",
    "test:kv": "node tests/kv_integrity_test.js",
    "test:listings-nodecount": "node tests/listings_query_node_limit_test.js",
    "test:listings-price-floor": "node tests/listings_price_floor_test.js",
    "test:listings-fields": "node tests/listings_metadata_field_test.js",
    "test:listings-modules": "node tests/listings_module_load_test.js",
    "test:listings-stale-removal": "node tests/listings_stale_removal_test.js",
    "test:listings": "npm run test:listings-modules && npm run test:listings-nodecount && npm run test:listings-price-floor && npm run test:listings-stale-removal && npm run test:listings-fields"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "jsdom": "^24.0.0",
    "wait-on": "^9.0.10",
    "wrangler": "4.112.0"
  }
}
